{
  "id": "tax-preparer-2025",
  "version": "2.0.0",
  "meta": {
    "title": "Tax Preparation Intake",
    "subtitle": "Help us scope your return and quote you a fair fee"
  },
  "start": "intro",
  "steps": {
    "intro": {
      "verb": "say",
      "text": "Short multiple-choice scoping questions — 2 to 3 minutes.\nPlease do NOT enter any personal information: no names,\nSSN, ITIN, addresses, or account numbers. We only need\nenough to quote a fee.",
      "transitions": [
        {
          "to": "residency_status"
        }
      ]
    },
    "residency_status": {
      "verb": "ask",
      "type": "enum",
      "question": "Which best describes your US tax residency for 2025?",
      "options": [
        {
          "value": "us_person",
          "label": "US citizen or permanent resident"
        },
        {
          "value": "resident",
          "label": "Resident alien (substantial presence)"
        },
        {
          "value": "non_resident",
          "label": "Non-resident alien (1040-NR)"
        },
        {
          "value": "dual_status",
          "label": "Dual-status (arrived or departed this year)"
        }
      ],
      "transitions": [
        {
          "to": "prior_return_available"
        }
      ],
      "widget": {
        "tty": {
          "type": "select"
        },
        "desktop": {
          "type": "radio_group",
          "columns": 2
        },
        "mobile": {
          "type": "dropdown"
        }
      }
    },
    "prior_return_available": {
      "verb": "ask",
      "type": "enum",
      "question": "Do you have a copy of your most recent tax return?",
      "options": [
        {
          "value": "yes_last_year",
          "label": "Yes, last year's return"
        },
        {
          "value": "yes_older",
          "label": "Yes, but older than last year"
        },
        {
          "value": "no",
          "label": "No"
        },
        {
          "value": "first_time",
          "label": "First return — never filed before"
        }
      ],
      "transitions": [
        {
          "to": "filing_status"
        }
      ],
      "widget": {
        "tty": {
          "type": "select"
        },
        "desktop": {
          "type": "radio_group",
          "columns": 2
        },
        "mobile": {
          "type": "dropdown"
        }
      }
    },
    "filing_status": {
      "verb": "ask",
      "type": "enum",
      "question": "What is your filing status for 2025?",
      "options": [
        {
          "value": "single",
          "label": "Single"
        },
        {
          "value": "married_filing_jointly",
          "label": "Married Filing Jointly"
        },
        {
          "value": "married_filing_separately",
          "label": "Married Filing Separately"
        },
        {
          "value": "head_of_household",
          "label": "Head of Household"
        },
        {
          "value": "widowed",
          "label": "Qualifying Widow(er)"
        }
      ],
      "transitions": [
        {
          "to": "dependents_band"
        }
      ],
      "widget": {
        "tty": {
          "type": "select"
        },
        "desktop": {
          "type": "radio_group",
          "columns": 1
        },
        "mobile": {
          "type": "dropdown"
        }
      }
    },
    "dependents_band": {
      "verb": "ask",
      "type": "enum",
      "question": "How many dependents will you claim?",
      "options": [
        {
          "value": "0",
          "label": "0"
        },
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4+",
          "label": "4+"
        }
      ],
      "transitions": [
        {
          "to": "income_types"
        }
      ],
      "widget": {
        "tty": {
          "type": "select"
        },
        "desktop": {
          "type": "radio_group",
          "columns": 5
        },
        "mobile": {
          "type": "dropdown"
        }
      }
    },
    "income_types": {
      "verb": "ask",
      "type": "multi_enum",
      "question": "Select every type of income you had in 2025.",
      "options": [
        {
          "value": "W2",
          "label": "W-2 wages"
        },
        {
          "value": "1099_nec",
          "label": "1099-NEC (contractor)"
        },
        {
          "value": "1099_k",
          "label": "1099-K (payment apps, marketplaces)"
        },
        {
          "value": "business",
          "label": "Business income (self-employed or entity)"
        },
        {
          "value": "investment",
          "label": "Investment income (brokerage, dividends)"
        },
        {
          "value": "crypto",
          "label": "Cryptocurrency"
        },
        {
          "value": "rental",
          "label": "Rental property"
        },
        {
          "value": "retirement",
          "label": "Retirement distributions (1099-R)"
        },
        {
          "value": "social_sec",
          "label": "Social Security"
        },
        {
          "value": "gambling",
          "label": "Gambling / lottery winnings"
        },
        {
          "value": "foreign",
          "label": "Foreign earned income"
        },
        {
          "value": "home_sale",
          "label": "Sold a home or primary residence"
        },
        {
          "value": "inheritance",
          "label": "Inheritance or large gift received"
        },
        {
          "value": "none",
          "label": "None of the above"
        }
      ],
      "transitions": [
        {
          "to": "w2_count",
          "rule": {
            "op": "contains",
            "field": "income_types",
            "value": "W2"
          }
        },
        {
          "to": "business_entities",
          "rule": {
            "op": "contains",
            "field": "income_types",
            "value": "business"
          }
        },
        {
          "to": "investment_details",
          "rule": {
            "op": "contains",
            "field": "income_types",
            "value": "investment"
          }
        },
        {
          "to": "crypto_volume",
          "rule": {
            "op": "contains",
            "field": "income_types",
            "value": "crypto"
          }
        },
        {
          "to": "rental_count",
          "rule": {
            "op": "contains",
            "field": "income_types",
            "value": "rental"
          }
        },
        {
          "to": "foreign_earned",
          "rule": {
            "op": "contains",
            "field": "income_types",
            "value": "foreign"
          }
        },
        {
          "to": "state_filing"
        }
      ],
      "widget": {
        "tty": {
          "type": "multi_select"
        },
        "desktop": {
          "type": "checkbox_group",
          "columns": 2
        },
        "mobile": {
          "type": "checkbox_group"
        }
      }
    },
