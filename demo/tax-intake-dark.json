{
  "id": "dark-theme-demo",
  "version": "1.0.0",
  "meta": {
    "title": "Midnight Studio",
    "subtitle": "A fully customized theme",
    "brand": { "name": "Midnight", "color": "#f59e0b" },
    "theme": {
      "background": "#0f172a",
      "surface": "#1e293b",
      "text": "#f1f5f9",
      "textMuted": "#94a3b8",
      "border": "#334155",
      "radius": "12px",
      "font": "Cairo, san-serif;",
      "headerFont": "'Bebas Neue', san-serif;"
    }
  },
  "start": "name",
  "steps": {
    "name": {
      "verb": "ask",
      "type": "string",
      "question": "What should we call you?",
      "transitions": [{ "to": "style" }]
    },
    "style": {
      "verb": "ask",
      "type": "enum",
      "question": "Pick a style",
      "options": [
        { "value": "a", "label": "Minimalist" },
        { "value": "b", "label": "Maximalist" },
        { "value": "c", "label": "Somewhere in between" }
      ],
      "transitions": [{ "to": "done" }]
    },
    "done": {
      "verb": "say",
      "text": "Thanks — your taste has been noted."
    }
  }
}
