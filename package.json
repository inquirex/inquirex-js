{
  "name": "inquirex-js",
  "version": "0.3.0",
  "description": "Embeddable copilot-style questionnaire widget powered by Inquirex flow definitions",
  "type": "module",
  "main": "dist/inquirex.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rvf dist node_modules; find . -name .DS_Store -delete -print"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@speed-highlight/core": "1.2.15",
    "@vitest/coverage-v8": "4.1.4",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "4.1.4"
  },
  "license": "MIT",
  "author": "Konstantin Gredeskoul <kigster@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/flowengine-rb/inquirex-js"
  }
}
