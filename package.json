{
  "name": "inquirex-js",
  "version": "0.1.0",
  "description": "Embeddable copilot-style questionnaire widget powered by Inquirex flow definitions",
  "type": "module",
  "main": "dist/inquirex.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rvf dist node_modules; find . -name .DS_Store -delete -print"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  },
  "license": "MIT",
  "author": "Konstantin Gredeskoul <kigster@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/flowengine-rb/inquirex-js"
  }
}
